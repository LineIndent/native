          "name": "variant",
          "type": "`Literal[\"default\", \"destructive\", \"outline\", \"secondary\", \"ghost\", \"link\"]`",
          "default": "`\"default\"`"
        },
        {
          "name": "size",
          "type": "`Literal[\"default\", \"xs\", \"sm\", \"lg\", \"icon\", \"icon-xs\", \"icon-sm\", \"icon-lg\"]`",
          "default": "`\"default\"`"
        },
        {
          "name": "class_name",
          "type": "`str`",
          "default": "`\"\"`"
        }
      ],
      "example": "button(\"Click me\", variant=\"outline\", size=\"sm\")"
    },
    {
      "component": "button_variants",
      "description": "Returns the same classes `button(...)` would apply, as a plain `Var[str]` \u2014 for styling a non-button element (like a link) to look like a button, without wrapping it in an actual `<button>`.",
      "props": [
        {
          "name": "Arg",
          "type": "Type",
          "default": "Default"
        },
        {
          "name": "variant",
          "type": "`Literal[\"default\", \"destructive\", \"outline\", \"secondary\", \"ghost\", \"link\"]`",
          "default": "`\"default\"`"
        },
        {
          "name": "size",
          "type": "`Literal[\"default\", \"xs\", \"sm\", \"lg\", \"icon\", \"icon-xs\", \"icon-sm\", \"icon-lg\"]`",
          "default": "`\"default\"`"
        }
      ],
      "example": "rx.el.a(\n    \"Go to docs\",\n    href=\"/docs\",\n    class_name=button_variants(\"outline\", \"sm\"),\n)"
    },
    {
      "component": "button_group.root",
