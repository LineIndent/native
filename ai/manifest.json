    {
      "component": "field.set",
      "description": "Container that renders a semantic `fieldset` with spacing presets.",
      "props": [
        {
          "name": "class_name",
          "type": "`str`",
          "default": null
        }
      ],
      "example": "field.set(\n    field.legend(\"Delivery\"),\n    field.group(),\n)"
    },
    {
      "component": "field.legend",
      "description": "Legend element for a `field.set`. Switch to the `\"label\"` variant to align with standard label sizing.",
      "props": [
        {
          "name": "variant",
          "type": "`Literal[\"legend\", \"label\"]`",
          "default": "`\"legend\"`"
        },
        {
          "name": "class_name",
          "type": "`str`",
          "default": null
        }
      ],
      "example": "field.legend(\"Notification Preferences\", variant=\"label\")"
    },
    {
      "component": "field.group",
      "description": "Layout wrapper that stacks `field.root` components and enables container queries for responsive orientations.",
      "props": [
        {
          "name": "class_name",
          "type": "`str`",
          "default": null
        }
      ],
      "example": "field.group(\n    field.root(),\n    field.root(),\n    class_name=\"@container/field-group flex flex-col gap-6\",\n)"
    },
    {
      "component": "field.root",
      "description": "The core wrapper for a single field. Provides orientation control, invalid state styling, and spacing configurations.",
      "props": [
        {
          "name": "orientation",
          "type": "`\"vertical\"",
          "default": "\"horizontal\""
        },
        {
          "name": "class_name",
          "type": "`str`",
          "default": null
        },
        {
          "name": "data_invalid",
          "type": "`str`",
          "default": null
        }
      ],
      "example": "field.root(\n    field.label(\"Remember me\", html_for=\"remember\"),\n    switch.root(id=\"remember\"),\n    orientation=\"horizontal\",\n)"
    },
    {
      "component": "field.content",
      "description": "Flex column that groups control and descriptions when the label sits beside the control. Not required if you have no layout description block.",
      "props": [
        {
          "name": "class_name",
          "type": "`str`",
          "default": null
        }
      ],
      "example": "field.root(\n    checkbox.root(id=\"notifications\"),\n    field.content(\n        field.label(\"Notifications\", html_for=\"notifications\"),\n        field.description(\"Email, SMS, and push options.\"),\n    ),\n)"
    },
    {
      "component": "field.label",
      "description": "Label styled for both direct inputs and nested `field` child items.",
      "props": [
        {
          "name": "html_for",
          "type": "`str`",
          "default": null
        },
        {
          "name": "class_name",
          "type": "`str`",
          "default": null
        }
      ],
      "example": "field.label(\"Email\", html_for=\"email\")"
    },
    {
      "component": "field.title",
      "description": "Renders a standalone title with matching label typography properties inside a `field.content` node block.",
