    {
      "component": "checkbox.root",
      "description": "Renders a `<label>` wrapping a visually-hidden `<input type=\"checkbox\">` and the indicator \u2014 clicking anywhere in the root toggles it, with no extra JS wiring required.",
      "props": [
        {
          "name": "id",
          "type": "`str`",
          "default": "auto-passed to input"
        },
        {
          "name": "checked",
          "type": "`bool`",
          "default": null
        },
        {
          "name": "default_checked",
          "type": "`bool`",
          "default": null
        },
        {
          "name": "disabled",
          "type": "`bool`",
          "default": "`False`"
        },
        {
          "name": "required",
          "type": "`bool`",
          "default": "`False`"
        },
        {
          "name": "name",
          "type": "`str`",
          "default": null
        },
        {
          "name": "value",
          "type": "`str`",
          "default": null
        },
        {
          "name": "on_change",
          "type": "`EventHandler`",
          "default": null
        },
        {
          "name": "class_name",
          "type": "`str`",
          "default": "`\"\"`"
        }
      ],
      "example": "checkbox.root(\n    checkbox.indicator(),\n    id=\"terms\",\n    default_checked=True,\n)"
    },
    {
      "component": "checkbox.indicator",
      "description": "The tick icon shown when the checkbox is checked, via `peer-checked:grid` \u2014 no `fallback_id`/`menu_id`-style wiring needed, it's a direct sibling of the input.",
      "props": [
        {
          "name": "class_name",
          "type": "`str`",
          "default": "`\"\"`"
        }
      ],
      "example": "checkbox.indicator(hi(\"Tick02Icon\"))"
    },
    {
      "component": "dialog.root",
      "description": "Non-visual scoping wrapper (`display: contents`, adds no layout box). Trigger and close resolve their target `<dialog>` by walking up to the nearest `dialog.root` \u2014 no manual id threading, and multiple independent dialogs on the same page (e.g. a per-row \"Share\" dialog) never cross-target each other.",
      "props": [
        {
          "name": "class_name",
          "type": "`str`",
          "default": "`\"\"`"
        }
      ],
      "example": "dialog.root(\n    dialog.trigger(button(\"Share\", variant=\"outline\")),\n    dialog.popup(...),\n)"
    },
    {
      "component": "dialog.trigger",
      "description": "Wraps its child (typically a `button(...)`) with a capturing click listener that calls `.showModal()` on the nearest `dialog.popup`. No visual box of its own, so nesting a styled button inside doesn't add extra layout depth.",
      "props": [
        {
          "name": "id",
          "type": "`str`",
          "default": "auto-generated"
        },
        {
          "name": "class_name",
          "type": "`str`",
          "default": "`\"\"`"
        }
      ],
      "example": "dialog.trigger(button(\"Share\", variant=\"outline\"))"
    },
    {
      "component": "dialog.popup",
      "description": "Renders the native `<dialog>`. Escape and backdrop clicks both close it when `dismissible=True` (the default).",
      "props": [
        {
          "name": "dismissible",
          "type": "`bool`",
          "default": "`True`"
        },
        {
          "name": "on_open_change",
          "type": "`EventHandler[[bool]] \\",
          "default": "None`"
        },
        {
          "name": "class_name",
          "type": "`str`",
          "default": "`\"\"`"
        }
      ],
      "example": "dialog.popup(\n    dialog.header(dialog.title(\"Share link\")),\n    ...,\n)"
    },
    {
      "component": "dialog.close",
      "description": "Same behavioral wrapper as `dialog.trigger`, but calls `.close()`. Has no default visual styling of its own \u2014 apply `dialog.class_names.CLOSE` / `dialog.class_names.CLOSE_ICON` to whatever you pass in.",
      "props": [
        {
          "name": "id",
          "type": "`str`",
          "default": "auto-generated"
        },
        {
          "name": "class_name",
          "type": "`str`",
          "default": "`\"\"`"
        }
      ],
      "example": "dialog.close(button(\"Close\", type=\"button\"))\n\ndialog.close(\n    button(\n        hi(\"Cancel01Icon\", class_name=\"size-4\"),\n        variant=\"ghost\",\n        size=\"icon-sm\",\n        class_name=dialog.class_names.CLOSE_ICON,\n    )\n)"
    },
    {
      "component": "dialog.title",
      "description": "",
      "props": [
        {
          "name": "class_name",
          "type": "`str`",
          "default": "`\"\"`"
        }
      ],
      "example": "dialog.title(\"Share link\")"
