        {
          "name": "src",
          "type": "`str`",
          "default": null
        },
        {
          "name": "id",
          "type": "`str`",
          "default": "auto-generated"
        },
        {
          "name": "class_name",
          "type": "`str`",
          "default": "`\"\"`"
        }
      ],
      "example": "avatar.image(src=\"/avatars/01.png\", custom_attrs={\"alt\": \"@shadcn\"})",
      "category": "components"
    },
    {
      "component": "avatar.fallback",
