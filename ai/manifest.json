    {
      "component": "avatar.root",
      "description": "The root component that wraps the avatar image and fallback.",
      "props": [
        {
          "name": "size",
          "type": "`Literal[\"default\", \"sm\", \"lg\", \"xl\"]`",
          "default": "`\"default\"`"
        },
        {
          "name": "class_name",
          "type": "`str`",
          "default": "`\"\"`"
        }
      ],
      "example": "avatar.root(\n    avatar.image(src=\"/avatars/01.png\"),\n    avatar.fallback(\"RD\"),\n)",
      "category": "components"
    },
    {
      "component": "avatar.image",
      "description": "Renders the `<img>` and probes its `src` client-side on mount \u2014 if it fails to load, it hides itself and reveals the sibling `avatar.fallback` automatically. No `fallback_id` wiring needed.",
