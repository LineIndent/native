{
  "components": [
    {
      "component": "accordion.root",
      "description": "",
      "props": [
        {
          "name": "class_name",
          "type": "`str`",
          "default": "`\"\"`"
        }
      ],
      "example": "accordion.root(\n    accordion.item(...),\n    accordion.item(...),\n)"
    },
    {
      "component": "accordion.item",
      "description": "Renders a native `<details>`. Give matching items the same `name` to make them mutually exclusive (native `<details name=\"...\">` grouping \u2014 opening one closes the others in the group automatically).",
      "props": [
        {
          "name": "name",
          "type": "`str`",
          "default": null
        },
        {
          "name": "class_name",
          "type": "`str`",
          "default": "`\"\"`"
        }
      ],
      "example": "accordion.item(\n    accordion.trigger(\"Is it accessible?\"),\n    accordion.panel(\"Yes, built on native semantics.\"),\n    name=\"faq\",\n)"
    },
    {
      "component": "accordion.trigger",
      "description": "Renders a `<summary>` with a chevron icon appended automatically \u2014 no need to add one yourself.",
      "props": [
        {
          "name": "class_name",
          "type": "`str`",
          "default": "`\"\"`"
        }
      ],
      "example": "accordion.trigger(\"Is it accessible?\")"
    },
