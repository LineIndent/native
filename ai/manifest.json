    {
      "component": "avatar.root",
      "description": "The root component that wraps the avatar image and fallback.",
      "props": [
        {
          "name": "size",
          "type": "`Literal[\"default\", \"sm\", \"lg\", \"xl\"]`",
          "default": "`\"default\"`"
        },
        {
          "name": "class_name",
          "type": "`str`",
          "default": "`\"\"`"
        }
      ],
      "example": "avatar.root(\n    avatar.image(src=\"/avatars/01.png\"),\n    avatar.fallback(\"RD\"),\n)"
    },
    {
      "component": "avatar.image",
      "description": "Renders the `<img>` and probes its `src` client-side on mount \u2014 if it fails to load, it hides itself and reveals the sibling `avatar.fallback` automatically. No `fallback_id` wiring needed.",
      "props": [
        {
          "name": "src",
          "type": "`str`",
          "default": null
        },
        {
          "name": "id",
          "type": "`str`",
          "default": "auto-generated"
        },
        {
          "name": "class_name",
          "type": "`str`",
          "default": "`\"\"`"
        }
      ],
      "example": "avatar.image(src=\"/avatars/01.png\", custom_attrs={\"alt\": \"@shadcn\"})"
    },
    {
      "component": "avatar.fallback",
      "description": "Shown automatically when `avatar.image` fails to load.",
      "props": [
        {
          "name": "class_name",
          "type": "`str`",
          "default": "`\"\"`"
        }
      ],
      "example": "avatar.fallback(\"RD\")"
    },
    {
      "component": "avatar.badge",
      "description": "Displays a badge indicator on the avatar, positioned at the bottom right by default.",
